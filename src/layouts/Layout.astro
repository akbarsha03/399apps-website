---
import '~/styles/global.css';
import { SITE, canonicalUrl } from '~/data/site';
import SEO from '~/components/SEO.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import { DEFAULT_LANG, localizedPath, HTML_LANG_ATTR, HREFLANGS, type Lang } from '~/data/i18n';

interface Props {
  title: string;
  description: string;
  path?: string;
  image?: string;
  type?: 'website' | 'article' | 'product';
  noindex?: boolean;
  keywords?: string[];
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /**
   * Emit this JSON-LD verbatim as the page's ONLY structured data, bypassing the
   * auto-injected Organization block. Use when the page supplies a complete,
   * pre-validated `@graph` that already declares its own Organization/WebSite
   * (e.g. the alternative/vs comparison cluster). Takes precedence over `jsonLd`.
   */
  rawJsonLd?: Record<string, unknown> | Record<string, unknown>[];
  hideChrome?: boolean;
  lang?: Lang;
  /** Path (in default-lang form) that has localized variants, for hreflang. */
  localizedOf?: string;
}

const props = Astro.props;
const lang = props.lang ?? DEFAULT_LANG;

const baseOrgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${SITE.url}/#organization`,
  name: SITE.name,
  alternateName: ['399Apps', '399 Apps'],
  url: canonicalUrl('/'),
  logo: new URL('/logo.png', SITE.url).toString(),
  description:
    '399apps is an affordable app store of business SaaS for Indian small businesses — GST-ready accounting (Nidhi Books) and inventory (Nidhi Inventory) software. ₹399/month for your first app, ₹99 per additional app, unlimited users, cloud or self-hosted.',
  slogan: SITE.tagline,
  foundingDate: SITE.founded,
  areaServed: { '@type': 'Country', name: 'India' },
  knowsAbout: [
    'GST accounting software',
    'GST billing software',
    'invoicing software',
    'inventory management software',
    'self-hosted business software',
    'GSTR-1 filing',
    'GSTR-3B filing',
    'e-invoicing',
    'e-way bill',
    'TDS',
  ],
  email: SITE.email,
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'sales',
    email: SITE.email,
    areaServed: 'IN',
    availableLanguage: ['en', 'hi', 'ta'],
  },
  founder: {
    '@type': 'Organization',
    name: SITE.builderName,
    url: SITE.builderUrl,
  },
  sameAs: Object.values(SITE.social),
};

const jsonLd = props.rawJsonLd
  ? (Array.isArray(props.rawJsonLd) ? props.rawJsonLd : [props.rawJsonLd])
  : props.jsonLd
    ? Array.isArray(props.jsonLd)
      ? [baseOrgSchema, ...props.jsonLd]
      : [baseOrgSchema, props.jsonLd]
    : [baseOrgSchema];

---

<!doctype html>
<html lang={HTML_LANG_ATTR[lang]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="x-build-time" content={new Date().toISOString()} />
    {props.localizedOf && (
      <>
        {HREFLANGS.map((h) => (
          <link rel="alternate" hreflang={h.code} href={canonicalUrl(localizedPath(props.localizedOf!, h.lang))} />
        ))}
        <link rel="alternate" hreflang="x-default" href={canonicalUrl(localizedPath(props.localizedOf!, 'en'))} />
      </>
    )}
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="shortcut icon" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {/* Load the font CSS non-blocking so it never blocks first render (CWV/LCP). */}
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      />
    </noscript>
    <meta name="generator" content={Astro.generator} />

    <SEO
      title={props.title}
      description={props.description}
      path={props.path}
      image={props.image}
      type={props.type}
      noindex={props.noindex}
      keywords={props.keywords}
      jsonLd={jsonLd}
    />

    {/* Paddle.js — checkout. Auto-opens checkout when the URL carries ?_ptxn=… */}
    <script is:inline src="https://cdn.paddle.com/paddle/v2/paddle.js"></script>
    <script is:inline>
      Paddle.Initialize({ token: 'live_3ec8d54530af94c865643627cda' });
    </script>
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-ink-900 focus:px-3 focus:py-2 focus:text-white">
      Skip to content
    </a>
    {!props.hideChrome && <Header lang={lang} />}
    <main id="main">
      <slot />
    </main>
    {!props.hideChrome && <Footer lang={lang} />}
  </body>
</html>
