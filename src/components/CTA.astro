---
import Icon from './Icon.astro';

interface Props {
  eyebrow?: string;
  title: string;
  body?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}
const {
  eyebrow = 'Get started',
  title,
  body,
  primaryLabel = 'Get a demo',
  primaryHref = '/contact?intent=demo',
  secondaryLabel = 'See pricing',
  secondaryHref = '/pricing',
} = Astro.props;
---

<section class="relative overflow-hidden">
  <div class="container-wide py-16 sm:py-20">
    <div class="relative overflow-hidden rounded-3xl border border-ink-100 bg-ink-900 px-8 py-14 text-white sm:px-14">
      <div class="pointer-events-none absolute inset-0 grid-bg opacity-[0.08]"></div>
      <div class="relative grid items-center gap-8 md:grid-cols-12">
        <div class="md:col-span-8">
          <span class="eyebrow !text-ink-300">{eyebrow}</span>
          <h2 class="mt-3 font-display text-3xl font-semibold tracking-tightish sm:text-4xl">
            {title}
          </h2>
          {body && <p class="mt-3 max-w-2xl text-base leading-relaxed text-ink-200">{body}</p>}
        </div>
        <div class="flex flex-col gap-3 sm:flex-row md:col-span-4 md:justify-end">
          <a href={primaryHref} class="btn bg-white text-ink-900 hover:bg-ink-100">
            {primaryLabel} <Icon name="arrow-right" size={16} />
          </a>
          <a href={secondaryHref} class="btn text-white ring-1 ring-inset ring-white/20 hover:bg-white/5">
            {secondaryLabel}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
