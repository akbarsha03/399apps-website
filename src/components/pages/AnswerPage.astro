---
import Layout from '~/layouts/Layout.astro';
import FAQ from '~/components/FAQ.astro';
import CTA from '~/components/CTA.astro';
import { ANSWERS } from '~/data/answers';
import { ANSWERS_JSONLD } from '~/data/answers-jsonld';

interface Props {
  slug: string;
}
const { slug } = Astro.props;
const a = ANSWERS[slug];

const ctaPrimary = `/contact?intent=cloud&utm_source=organic&utm_medium=answers-hub&utm_campaign=${slug}&utm_content=primary-cta`;
const ctaSecondary = `/contact?intent=demo&utm_source=organic&utm_medium=answers-hub&utm_campaign=${slug}&utm_content=secondary-demo`;
---

<Layout title={a.metaTitle} description={a.metaDescription} type="article" keywords={a.keywords} rawJsonLd={ANSWERS_JSONLD[slug]}>
  <section class="relative overflow-hidden border-b border-ink-100">
    <div class="pointer-events-none absolute inset-0 grid-bg opacity-70"></div>
    <div class="container-wide relative py-16 sm:py-20">
      <nav class="mb-8 text-xs text-ink-500" aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-1.5">
          <li><a href="/" class="hover:text-ink-700">Home</a></li>
          <li class="text-ink-400">/</li>
          <li><a href="/answers/" class="hover:text-ink-700">Answers</a></li>
          <li class="text-ink-400">/</li>
          <li class="text-ink-800">{a.question}</li>
        </ol>
      </nav>
      <span class="eyebrow">{a.eyebrow}</span>
      <h1 class="h1 mt-4 max-w-4xl">{a.question}</h1>

      <div class="mt-6 max-w-3xl rounded-2xl border border-ink-100 bg-white/70 p-6 shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Short answer</p>
        <p class="mt-2 text-[17px] leading-relaxed text-ink-800">{a.directAnswer}</p>
      </div>

      <div class="mt-7 flex flex-wrap gap-3">
        <a href={ctaPrimary} class="btn-primary">Start your free 14-day trial</a>
        <a href={ctaSecondary} class="btn-secondary">Get a free demo</a>
      </div>
      <p class="mt-3 text-xs text-ink-500">14-day free trial · No card required · Cancel anytime</p>
    </div>
  </section>

  {a.sections.map((s) => (
    <section class="bg-white">
      <div class="container-narrow py-14 sm:py-16">
        <h2 class="h2">{s.h2}</h2>
        {s.paras.map((p) => (
          <p class="mt-4 text-[17px] leading-relaxed text-ink-700">{p}</p>
        ))}
      </div>
    </section>
  ))}

  <section class="border-t border-ink-100 bg-ink-50/40">
    <div class="container-narrow py-12 sm:py-14">
      <span class="eyebrow">Keep reading</span>
      <h2 class="h2 mt-3">Related comparisons & guides</h2>
      <ul class="mt-5 grid gap-3 sm:grid-cols-2">
        {a.related.map((r) => (
          <li>
            <a href={r.href} class="flex items-center gap-2 rounded-xl border border-ink-100 bg-white px-4 py-3 text-[15px] font-medium text-ink-800 transition hover:border-ink-200 hover:shadow-sm">
              {r.label} <span class="text-brand-700">&rarr;</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <FAQ items={a.faqs} title="More questions" />

  <CTA
    eyebrow="Try 399Apps"
    title="Affordable GST software from ₹399/month"
    body="Cloud GST billing, accounting and inventory with unlimited users. Start a free 14-day trial — no card required."
    primaryLabel="Start free trial"
    primaryHref={ctaPrimary}
    secondaryLabel="See pricing"
    secondaryHref="/pricing"
  />
</Layout>
