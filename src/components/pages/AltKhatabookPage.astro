---
import Layout from '~/layouts/Layout.astro';
import FAQ from '~/components/FAQ.astro';
import CTA from '~/components/CTA.astro';
import { ALT_JSONLD } from '~/data/alt-jsonld';
import { localizedPath, type Lang } from '~/data/i18n';
import { getAltKhatabookCopy } from '~/data/i18n/alt-khatabook-alternative';
import { localizeAltGraph } from '~/data/i18n/localize-graph';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getAltKhatabookCopy(lang);

const SLUG = 'khatabook-alternative';
const BASE = '/khatabook-alternative/';

const enGraph = ALT_JSONLD[SLUG]['@graph'] as Array<Record<string, any>>;
const graph = localizeAltGraph(enGraph, lang, BASE, t.faq.items, { name: t.seo.title, description: t.seo.description }, t.breadcrumbLeaf);
const rawJsonLd = { '@context': 'https://schema.org', '@graph': graph };

const faqs = t.faq.items.map((f) => ({ q: f.q, a: f.a }));

const ctaPrimary = 'https://books.399apps.com/sign-up';
const ctaSecondary = localizedPath(`/contact?intent=demo&utm_source=organic&utm_medium=alt-vs-cluster&utm_campaign=${SLUG}&utm_content=secondary-demo`, lang);

const L = (p: string) => localizedPath(p, lang);

// Related links: hrefs taken from the EN page, labels from the data (same order).
// '/mybillbook-alternative/' has no locale variant — leave it EN-only (unlocalized).
const LOCALIZED_RELATED = new Set(['/vyapar-alternative/', '/zoho-books-alternative/', '/best/gst-software-india/', '/best/accounting-software-small-business-india/', '/apps/books/', '/pricing/']);
const relLink = (p: string) => (LOCALIZED_RELATED.has(p) ? L(p) : p);
const relatedHrefs = ['/vyapar-alternative/', '/mybillbook-alternative/', '/zoho-books-alternative/', '/best/gst-software-india/', '/best/accounting-software-small-business-india/', '/apps/books/', '/pricing/'];
const relatedLinks = t.related.links.map((label, i) => ({ label, href: relLink(relatedHrefs[i]) }));
---

<Layout title={t.seo.title} description={t.seo.description} type="product" keywords={t.seo.keywords} rawJsonLd={rawJsonLd} lang={lang} localizedOf={BASE}>
  <section class="relative overflow-hidden border-b border-ink-100">
    <div class="pointer-events-none absolute inset-0 grid-bg opacity-70"></div>
    <div class="container-wide relative py-16 sm:py-20">
      <nav class="mb-8 text-xs text-ink-500" aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-1.5">
          <li><a href={L('/')} class="hover:text-ink-700">Home</a></li>
          <li class="text-ink-400">/</li>
          <li class="text-ink-800">{t.breadcrumbLeaf}</li>
        </ol>
      </nav>
      <span class="eyebrow">{t.hero.eyebrow}</span>
      <h1 class="h1 mt-4 max-w-4xl">{t.hero.h1}</h1>
      <p class="lede mt-5 max-w-3xl" set:html={t.hero.lede}></p>
      <div class="mt-7 flex flex-wrap gap-3">
        <a href={ctaPrimary} class="btn-primary">{t.hero.primaryLabel}</a>
        <a href={ctaSecondary} class="btn-secondary">{t.hero.secondaryLabel}</a>
      </div>
      <p class="mt-3 text-xs text-ink-500">{t.hero.microcopy}</p>
    </div>
  </section>

  <section class="bg-white">
    <div class="container-narrow py-16 sm:py-20">
      <h2 class="h2">{t.whatIs.h2}</h2>
      <p class="mt-4 text-[17px] leading-relaxed text-ink-700" set:html={t.whatIs.body[0]}></p>
      <p class="mt-4 text-[17px] leading-relaxed text-ink-700" set:html={t.whatIs.body[1]}></p>
    </div>
  </section>

  <section class="border-t border-ink-100 bg-ink-50/40">
    <div class="container-narrow py-16 sm:py-20">
      <span class="eyebrow">{t.glance.eyebrow}</span>
      <h2 class="h2 mt-3">{t.glance.h2}</h2>
      <div class="mt-6 overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr class="border-b border-ink-200 text-left">
              <th class="py-3 pr-4 font-semibold text-ink-900">{t.glance.table.head[0]}</th>
              <th class="py-3 pr-4 font-semibold text-ink-900">{t.glance.table.head[1]}</th>
              <th class="py-3 pr-4 font-semibold text-ink-900">{t.glance.table.head[2]}</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-ink-100">
            {t.glance.table.rows.map((r) => (
              <tr>
                <td class="py-3 pr-4 font-medium text-ink-900">{r.label}</td>
                <td class="py-3 pr-4 text-ink-700">{r.a}</td>
                <td class="py-3 pr-4 text-ink-700">{r.b}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-3 text-xs italic text-ink-500">{t.glance.note}</p>
      <p class="mt-6 rounded-2xl border border-amber-200 bg-amber-50 px-5 py-4 text-sm leading-relaxed text-amber-900">{t.glance.honestNote}</p>
    </div>
  </section>

  <section class="bg-white">
    <div class="container-narrow py-16 sm:py-20">
      <h2 class="h2">{t.switchReasons.h2}</h2>
      <ol class="mt-5 list-decimal space-y-3 pl-5 text-[15px] leading-relaxed text-ink-700">
        {t.switchReasons.items.map((item) => (
          <li set:html={item}></li>
        ))}
      </ol>
    </div>
  </section>

  <section class="border-t border-ink-100 bg-ink-50/40">
    <div class="container-narrow py-16 sm:py-20">
      <h2 class="h2">{t.gstAdvantage.h2}</h2>
      <p class="mt-4 text-[17px] leading-relaxed text-ink-700">{t.gstAdvantage.intro}</p>
      <ul class="mt-5 space-y-3 text-[15px] leading-relaxed text-ink-700">
        {t.gstAdvantage.bullets.map((b) => (
          <li>{b}</li>
        ))}
      </ul>
    </div>
  </section>

  <section class="bg-white">
    <div class="container-narrow py-16 sm:py-20">
      <h2 class="h2">{t.migrate.h2}</h2>
      <ol class="mt-5 list-decimal space-y-3 pl-5 text-[15px] leading-relaxed text-ink-700">
        {t.migrate.steps.map((step) => (
          <li set:html={step}></li>
        ))}
      </ol>
      <p class="mt-6 rounded-2xl border border-amber-200 bg-amber-50 px-5 py-4 text-sm leading-relaxed text-amber-900">{t.migrate.tip}</p>
    </div>
  </section>

  <section class="border-t border-ink-100 bg-ink-50/40">
    <div class="container-narrow py-16 sm:py-20">
      <h2 class="h2">{t.whenAlt.h2}</h2>
      <p class="mt-4 text-[17px] leading-relaxed text-ink-700">{t.whenAlt.body}</p>
    </div>
  </section>

  <FAQ items={faqs} title={t.faq.title} />

  <section class="border-t border-ink-100 bg-ink-50/40">
    <div class="container-narrow py-12">
      <p class="eyebrow">{t.related.title}</p>
      <ul class="mt-3 flex flex-wrap gap-x-6 gap-y-2 text-sm text-brand-700">
        {relatedLinks.map((r) => (
          <li><a class="hover:underline" href={r.href}>{r.label}</a></li>
        ))}
      </ul>
    </div>
  </section>

  <CTA
    eyebrow={t.cta.eyebrow}
    title={t.cta.title}
    body={t.cta.body}
    primaryLabel={t.cta.primaryLabel}
    primaryHref={ctaPrimary}
    secondaryLabel={t.cta.secondaryLabel}
    secondaryHref={ctaSecondary}
  />
</Layout>
