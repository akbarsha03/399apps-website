---
import Layout from '~/layouts/Layout.astro';
import Icon from '~/components/Icon.astro';
import CTA from '~/components/CTA.astro';
import FAQ from '~/components/FAQ.astro';
import { getSelfHostingCopy, localizedPath, type Lang } from '~/data/i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getSelfHostingCopy(lang);

const selfhostHref = localizedPath('/contact?intent=selfhost', lang);
const compareHref = localizedPath('/cloud-vs-self-hosted', lang);
const pricingHref = localizedPath('/pricing', lang);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  inLanguage: lang,
  mainEntity: t.faq.items.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Layout
  title={t.seo.title}
  description={t.seo.description}
  keywords={t.seo.keywords}
  jsonLd={jsonLd}
  lang={lang}
  localizedOf="/self-hosting"
>
  <section class="relative overflow-hidden border-b border-ink-100">
    <div class="pointer-events-none absolute inset-0 grid-bg opacity-60"></div>
    <div class="container-wide relative py-16 sm:py-20">
      <div class="mx-auto max-w-3xl text-center">
        <span class="eyebrow">{t.hero.eyebrow}</span>
        <h1 class="h1 mt-5">{t.hero.title}</h1>
        <p class="lede mt-5">{t.hero.lede}</p>
        <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a href={selfhostHref} class="btn-primary">{t.hero.primaryCta} <Icon name="arrow-right" size={16} /></a>
          <a href={compareHref} class="btn-secondary">{t.hero.secondaryCta}</a>
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-ink-100 bg-white">
    <div class="container-wide py-16 sm:py-20">
      <div class="grid gap-10 lg:grid-cols-12">
        <div class="lg:col-span-5">
          <span class="eyebrow">{t.why.eyebrow}</span>
          <h2 class="h2 mt-3">{t.why.title}</h2>
          <p class="lede mt-4">{t.why.lede}</p>
        </div>
        <div class="grid gap-5 lg:col-span-7 sm:grid-cols-2">
          {t.why.cards.map((f) => (
            <article class="card">
              <span class="grid h-10 w-10 place-items-center rounded-lg bg-ink-50 text-ink-700">
                <Icon name={f.icon as any} size={20} />
              </span>
              <h3 class="mt-4 font-display text-base font-semibold tracking-tightish text-ink-900">{f.t}</h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-600">{f.b}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white">
    <div class="container-narrow py-16 sm:py-20">
      <div class="mb-10 max-w-2xl">
        <span class="eyebrow">{t.how.eyebrow}</span>
        <h2 class="h2 mt-3">{t.how.title}</h2>
      </div>

      <ol class="space-y-5">
        {t.how.steps.map((s, i) => (
          <li class="grid gap-2 rounded-2xl border border-ink-100 bg-white p-6 sm:grid-cols-12">
            <div class="sm:col-span-2">
              <span class="grid h-9 w-9 place-items-center rounded-lg bg-ink-900 font-display text-sm font-semibold text-white">0{i + 1}</span>
            </div>
            <div class="sm:col-span-10">
              <h3 class="font-display text-base font-semibold tracking-tightish text-ink-900">{s.t}</h3>
              <p class="mt-1 text-sm leading-relaxed text-ink-600">{s.b}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <FAQ items={t.faq.items} title={t.faq.title} />

  <CTA
    eyebrow={t.finalCta.eyebrow}
    title={t.finalCta.title}
    body={t.finalCta.body}
    primaryLabel={t.finalCta.primaryLabel}
    primaryHref={selfhostHref}
    secondaryLabel={t.finalCta.secondaryLabel}
    secondaryHref={pricingHref}
  />
</Layout>
