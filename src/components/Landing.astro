---
import AppCard from '~/components/AppCard.astro';
import Icon from '~/components/Icon.astro';
import CTA from '~/components/CTA.astro';
import FAQ from '~/components/FAQ.astro';
import { APPS } from '~/data/apps';
import { getTranslations, localizedPath, type Lang } from '~/data/i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getTranslations(lang);

const demoHref = localizedPath('/contact?intent=demo', lang);
const pricingHref = localizedPath('/pricing', lang);
const selfHostHref = localizedPath('/self-hosting', lang);
const compareHref = localizedPath('/cloud-vs-self-hosted', lang);
---

<!-- Hero -->
<section class="relative overflow-hidden border-b border-ink-100">
  <div class="pointer-events-none absolute inset-0 grid-bg"></div>
  <div class="pointer-events-none absolute -top-40 left-1/2 h-[440px] w-[820px] -translate-x-1/2 rounded-full bg-gradient-to-tr from-brand-200/50 via-rose-200/40 to-amber-200/40 blur-3xl"></div>

  <div class="container-wide relative py-20 sm:py-28">
    <div class="mx-auto max-w-3xl text-center">
      <span class="eyebrow">
        <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
        {t.hero.eyebrow}
      </span>
      <h1 class="h1 mt-5">
        {t.hero.titleLead} <span class="bg-gradient-to-r from-brand-700 via-brand-500 to-amber-500 bg-clip-text text-transparent">{t.hero.titleHighlight}</span>
      </h1>
      <p class="lede mx-auto mt-5 max-w-2xl">{t.hero.lede}</p>
      <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href="#apps" class="btn-primary">
          {t.hero.ctaBrowse} <Icon name="arrow-right" size={16} />
        </a>
        <a href={demoHref} class="btn-secondary">
          {t.hero.ctaDemo}
        </a>
      </div>

      <ul class="mt-10 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs text-ink-500">
        {t.hero.badges.map((badge) => (
          <li class="inline-flex items-center gap-1.5"><Icon name="check" size={14} class="text-emerald-600" /> {badge}</li>
        ))}
      </ul>
    </div>
  </div>
</section>

<!-- Trust strip -->
<section class="border-b border-ink-100 bg-ink-50/40">
  <div class="container-wide py-8">
    <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
      {t.stats.map((stat) => (
        <div>
          <p class="text-2xl font-semibold tracking-tightish text-ink-900">
            {stat.value}{('valueSuffix' in stat) && <span class="text-base font-normal text-ink-400">{(stat as any).valueSuffix}</span>}
          </p>
          <p class="text-xs uppercase tracking-wider text-ink-500">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Apps grid -->
<section id="apps" class="bg-white">
  <div class="container-wide py-20 sm:py-24">
    <div class="mx-auto mb-12 max-w-2xl text-center">
      <span class="eyebrow">{t.apps.eyebrow}</span>
      <h2 class="h2 mt-3">{t.apps.title}</h2>
      <p class="lede mt-3">{t.apps.lede}</p>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {APPS.map((app) => <AppCard app={app} />)}
    </div>
  </div>
</section>

<!-- Cloud vs Self-host -->
<section class="border-y border-ink-100 bg-ink-50/40">
  <div class="container-wide py-20 sm:py-24">
    <div class="grid items-start gap-12 lg:grid-cols-12">
      <div class="lg:col-span-5">
        <span class="eyebrow">{t.modes.eyebrow}</span>
        <h2 class="h2 mt-3">{t.modes.title}</h2>
        <p class="lede mt-4">{t.modes.lede}</p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href={selfHostHref} class="btn-secondary">{t.modes.selfHostCta}</a>
          <a href={compareHref} class="btn-ghost">{t.modes.compareCta} <Icon name="arrow-right" size={14} /></a>
        </div>
      </div>

      <div class="grid gap-4 lg:col-span-7 sm:grid-cols-2">
        <article class="card">
          <div class="flex items-center gap-3">
            <span class="grid h-10 w-10 place-items-center rounded-lg bg-gradient-to-br from-brand-500 to-brand-700 text-white">
              <Icon name="cloud" size={20} />
            </span>
            <h3 class="font-display text-lg font-semibold tracking-tightish">{t.modes.cloud.title}</h3>
          </div>
          <p class="mt-3 text-[14.5px] leading-relaxed text-ink-600">{t.modes.cloud.body}</p>
          <ul class="mt-4 space-y-1.5 text-sm text-ink-700">
            {t.modes.cloud.features.map((f) => (
              <li class="flex gap-2"><Icon name="check" size={14} class="mt-1 text-emerald-600" /> {f}</li>
            ))}
          </ul>
        </article>
        <article class="card">
          <div class="flex items-center gap-3">
            <span class="grid h-10 w-10 place-items-center rounded-lg bg-gradient-to-br from-ink-700 to-ink-900 text-white">
              <Icon name="server" size={20} />
            </span>
            <h3 class="font-display text-lg font-semibold tracking-tightish">{t.modes.selfHost.title}</h3>
          </div>
          <p class="mt-3 text-[14.5px] leading-relaxed text-ink-600">{t.modes.selfHost.body}</p>
          <ul class="mt-4 space-y-1.5 text-sm text-ink-700">
            {t.modes.selfHost.features.map((f) => (
              <li class="flex gap-2"><Icon name="check" size={14} class="mt-1 text-emerald-600" /> {f}</li>
            ))}
          </ul>
        </article>
      </div>
    </div>
  </div>
</section>

<!-- Why us -->
<section class="bg-white">
  <div class="container-wide py-20 sm:py-24">
    <div class="mb-12 max-w-2xl">
      <span class="eyebrow">{t.why.eyebrow}</span>
      <h2 class="h2 mt-3">{t.why.title}</h2>
      <p class="lede mt-3">{t.why.lede}</p>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {t.why.cards.map((f) => (
        <article class="card">
          <span class="grid h-10 w-10 place-items-center rounded-lg bg-ink-50 text-ink-700">
            <Icon name={f.icon as any} size={20} />
          </span>
          <h3 class="mt-4 font-display text-base font-semibold tracking-tightish text-ink-900">{f.t}</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-600">{f.b}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<FAQ items={t.faq.items} title={t.faq.title} description={t.faq.description} />

<CTA
  eyebrow={t.finalCta.eyebrow}
  title={t.finalCta.title}
  body={t.finalCta.body}
  primaryLabel={t.finalCta.primaryLabel}
  primaryHref={demoHref}
  secondaryLabel={t.finalCta.secondaryLabel}
  secondaryHref={pricingHref}
/>
