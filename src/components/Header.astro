---
import { SITE } from '~/data/site';
import Icon from './Icon.astro';
import { getChromeCopy, localizedPath, LANGUAGES, DEFAULT_LANG, HTML_LANG_ATTR, type Lang } from '~/data/i18n';

interface Props {
  lang?: Lang;
}
const { lang = DEFAULT_LANG } = Astro.props;
const t = getChromeCopy(lang);
const pathname = Astro.url.pathname;

const home = localizedPath('/', lang);
const nav = [
  { label: t.header.nav.apps, href: home === '/' ? '/#apps' : `${home}#apps` },
  { label: t.header.nav.pricing, href: localizedPath('/pricing', lang) },
  { label: t.header.nav.selfHosting, href: localizedPath('/self-hosting', lang) },
  { label: t.header.nav.whiteLabel, href: localizedPath('/white-label', lang) },
  { label: t.header.nav.contact, href: localizedPath('/contact', lang) },
];

const hreflangCode = HTML_LANG_ATTR;
const contactHref = localizedPath('/contact', lang);
const current = LANGUAGES.find((l) => l.code === lang) ?? LANGUAGES[0];
---

<header class="sticky top-0 z-40 border-b border-ink-100 bg-white/85 backdrop-blur-md">
  <div class="container-wide flex h-16 items-center justify-between gap-3">
    <a href={home} class="group flex items-center gap-2.5" aria-label={`${SITE.name} home`}>
      <img
        src="/logo.png"
        alt="399apps.com logo"
        width="32"
        height="32"
        loading="eager"
        decoding="async"
        class="h-8 w-8 rounded-lg shadow-[0_4px_12px_-6px_rgba(220,38,38,0.7)]"
      />
      <span class="font-display text-[15px] font-semibold tracking-tightish text-ink-900">
        {SITE.name}<span class="text-ink-400">.com</span>
      </span>
    </a>

    <nav class="hidden items-center gap-1 lg:flex" aria-label="Primary">
      {nav.map((item) => (
        <a
          href={item.href}
          class="rounded-full px-3.5 py-1.5 text-sm text-ink-600 transition-colors hover:text-ink-900"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <!-- Language switcher (dropdown) -->
      <details class="group relative hidden sm:block" data-lang-switch>
        <summary
          class="flex cursor-pointer list-none items-center gap-1.5 rounded-full border border-ink-200 px-3 py-1.5 text-xs font-medium text-ink-700 transition-colors hover:border-ink-300 [&::-webkit-details-marker]:hidden"
          aria-label={t.header.languageLabel}
        >
          <Icon name="globe" size={14} />
          <span>{current.short}</span>
          <span class="text-ink-400 transition-transform group-open:rotate-180">▾</span>
        </summary>
        <div class="absolute right-0 z-50 mt-2 w-48 overflow-hidden rounded-xl border border-ink-100 bg-white p-1 shadow-[0_12px_40px_-12px_rgba(15,23,42,0.25)]">
          {LANGUAGES.map((l) => {
            const active = l.code === lang;
            return (
              <a
                href={localizedPath(pathname, l.code)}
                hreflang={hreflangCode[l.code]}
                aria-current={active ? 'true' : undefined}
                class:list={[
                  'flex items-center justify-between rounded-lg px-3 py-2 text-sm transition-colors',
                  active ? 'bg-ink-50 font-medium text-ink-900' : 'text-ink-700 hover:bg-ink-50',
                ]}
              >
                <span>{l.label}</span>
                {active && <Icon name="check" size={14} class="text-emerald-600" />}
              </a>
            );
          })}
        </div>
      </details>

      <a href={contactHref} class="hidden btn-secondary lg:inline-flex">
        {t.header.talkToSales}
      </a>
      <a href={localizedPath('/contact?intent=demo', lang)} class="btn-primary">
        <span>{t.header.getDemo}</span>
        <Icon name="arrow-right" size={16} />
      </a>
      <button
        type="button"
        class="grid h-9 w-9 place-items-center rounded-md text-ink-700 hover:bg-ink-50 lg:hidden"
        aria-label="Open menu"
        data-menu-toggle
      >
        <Icon name="menu" />
      </button>
    </div>
  </div>

  <div class="hidden border-t border-ink-100 bg-white lg:hidden" data-menu-panel>
    <nav class="container-wide flex flex-col gap-1 py-3" aria-label="Mobile">
      {nav.map((item) => (
        <a href={item.href} class="rounded-lg px-3 py-2 text-sm text-ink-700 hover:bg-ink-50">
          {item.label}
        </a>
      ))}
      <a href={contactHref} class="btn-secondary mt-2 justify-center">{t.header.talkToSales}</a>

      <div class="mt-3 border-t border-ink-100 pt-3">
        <p class="px-3 text-xs uppercase tracking-wider text-ink-500">{t.header.languageLabel}</p>
        <div class="mt-1.5 flex gap-1.5 px-3">
          {LANGUAGES.map((l) => {
            const active = l.code === lang;
            return (
              <a
                href={localizedPath(pathname, l.code)}
                hreflang={hreflangCode[l.code]}
                class:list={[
                  'rounded-full border px-3 py-1 text-xs font-medium transition-colors',
                  active ? 'border-ink-900 bg-ink-900 text-white' : 'border-ink-200 text-ink-700 hover:border-ink-300',
                ]}
              >
                {l.label}
              </a>
            );
          })}
        </div>
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const panel = document.querySelector<HTMLElement>('[data-menu-panel]');
  toggle?.addEventListener('click', () => {
    panel?.classList.toggle('hidden');
  });

  // Close the language dropdown when clicking outside it.
  const langSwitch = document.querySelector<HTMLDetailsElement>('[data-lang-switch]');
  document.addEventListener('click', (e) => {
    if (langSwitch && langSwitch.open && !langSwitch.contains(e.target as Node)) {
      langSwitch.open = false;
    }
  });
</script>
