---
import { SITE } from '~/data/site';
import { APPS } from '~/data/apps';
import Icon from './Icon.astro';
import { getChromeCopy, localizedPath, DEFAULT_LANG, type Lang } from '~/data/i18n';

interface Props {
  lang?: Lang;
}
const { lang = DEFAULT_LANG } = Astro.props;
const t = getChromeCopy(lang);

const home = localizedPath('/', lang);
const year = new Date().getFullYear();
---

<footer class="border-t border-ink-100 bg-ink-50/40">
  <div class="container-wide py-14">
    <div class="grid gap-12 md:grid-cols-12">
      <div class="md:col-span-4">
        <a href={home} class="flex items-center gap-2.5" aria-label={`${SITE.name} home`}>
          <img
            src="/logo.png"
            alt="399apps.com logo"
            width="32"
            height="32"
            loading="lazy"
            decoding="async"
            class="h-8 w-8 rounded-lg shadow-[0_4px_12px_-6px_rgba(220,38,38,0.7)]"
          />
          <span class="font-display text-[15px] font-semibold tracking-tightish text-ink-900">
            {SITE.name}<span class="text-ink-400">.com</span>
          </span>
        </a>
        <p class="mt-4 max-w-sm text-sm leading-relaxed text-ink-600">
          {SITE.description}
        </p>
        <p class="mt-6 text-xs text-ink-500">
          {t.footer.builtBy}
          {' '}
          <a href={SITE.builderUrl} class="font-medium text-ink-800 underline-offset-2 hover:underline" target="_blank" rel="noopener">
            {SITE.builderName}
          </a>.
        </p>
      </div>

      <div class="md:col-span-2">
        <h4 class="text-xs font-semibold uppercase tracking-wider text-ink-500">{t.footer.apps}</h4>
        <ul class="mt-4 space-y-2 text-sm">
          {APPS.map((app) => (
            <li>
              <a href={localizedPath(`/apps/${app.slug}`, lang)} class="text-ink-700 hover:text-ink-900">
                {app.shortName}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="md:col-span-2">
        <h4 class="text-xs font-semibold uppercase tracking-wider text-ink-500">{t.footer.product}</h4>
        <ul class="mt-4 space-y-2 text-sm">
          <li><a href={localizedPath('/pricing', lang)} class="text-ink-700 hover:text-ink-900">{t.footer.pricing}</a></li>
          <li><a href={localizedPath('/self-hosting', lang)} class="text-ink-700 hover:text-ink-900">{t.footer.selfHosting}</a></li>
          <li><a href={localizedPath('/white-label', lang)} class="text-ink-700 hover:text-ink-900">{t.footer.whiteLabel}</a></li>
          <li><a href={localizedPath('/cloud-vs-self-hosted', lang)} class="text-ink-700 hover:text-ink-900">{t.footer.cloudVsSelf}</a></li>
        </ul>
      </div>

      <div class="md:col-span-2">
        <h4 class="text-xs font-semibold uppercase tracking-wider text-ink-500">{t.footer.company}</h4>
        <ul class="mt-4 space-y-2 text-sm">
          <li><a href={localizedPath('/about', lang)} class="text-ink-700 hover:text-ink-900">{t.footer.about}</a></li>
          <li><a href={localizedPath('/contact', lang)} class="text-ink-700 hover:text-ink-900">{t.footer.contactLink}</a></li>
          <li><a href={localizedPath('/privacy', lang)} class="text-ink-700 hover:text-ink-900">{t.footer.privacy}</a></li>
          <li><a href="/terms" class="text-ink-700 hover:text-ink-900">{t.footer.terms}</a></li>
        </ul>
      </div>

      <div class="md:col-span-2">
        <h4 class="text-xs font-semibold uppercase tracking-wider text-ink-500">{t.footer.contact}</h4>
        <ul class="mt-4 space-y-2 text-sm">
          <li>
            <a href={`mailto:${SITE.email}`} class="inline-flex items-center gap-2 text-ink-700 hover:text-ink-900">
              <Icon name="mail" size={14} /> {SITE.email}
            </a>
          </li>
          <li>
            <a href={SITE.builderUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-ink-700 hover:text-ink-900">
              <Icon name="globe" size={14} /> shabuilds.tech
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-start justify-between gap-4 border-t border-ink-100 pt-8 text-xs text-ink-500 sm:flex-row sm:items-center">
      <p>© {year} {SITE.name}. {t.footer.rights}</p>
      <p>
        {t.footer.madeIn}
        {' '}
        <a href={SITE.builderUrl} target="_blank" rel="noopener" class="text-ink-700 underline-offset-2 hover:underline">
          shabuilds.tech ↗
        </a>
      </p>
    </div>
  </div>
</footer>
