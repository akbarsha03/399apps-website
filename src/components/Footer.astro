---
import { SITE } from '~/data/site';
import { APPS } from '~/data/apps';
import Icon from './Icon.astro';

const year = new Date().getFullYear();
---

<footer class="border-t border-ink-100 bg-ink-50/40">
  <div class="container-wide py-14">
    <div class="grid gap-12 md:grid-cols-12">
      <div class="md:col-span-4">
        <a href="/" class="flex items-center gap-2.5" aria-label={`${SITE.name} home`}>
          <span class="grid h-8 w-8 place-items-center rounded-lg bg-brand-600 text-white shadow-[0_4px_12px_-6px_rgba(220,38,38,0.7)]">
            <span class="font-display text-[13px] font-extrabold tracking-tight">399</span>
          </span>
          <span class="font-display text-[15px] font-semibold tracking-tightish text-ink-900">
            {SITE.name}<span class="text-ink-400">.com</span>
          </span>
        </a>
        <p class="mt-4 max-w-sm text-sm leading-relaxed text-ink-600">
          {SITE.description}
        </p>
        <p class="mt-6 text-xs text-ink-500">
          Built, deployed and maintained by
          {' '}
          <a href={SITE.builderUrl} class="font-medium text-ink-800 underline-offset-2 hover:underline" target="_blank" rel="noopener">
            {SITE.builderName}
          </a>.
        </p>
      </div>

      <div class="md:col-span-2">
        <h4 class="text-xs font-semibold uppercase tracking-wider text-ink-500">Apps</h4>
        <ul class="mt-4 space-y-2 text-sm">
          {APPS.map((app) => (
            <li>
              <a href={`/apps/${app.slug}`} class="text-ink-700 hover:text-ink-900">
                {app.shortName}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="md:col-span-2">
        <h4 class="text-xs font-semibold uppercase tracking-wider text-ink-500">Product</h4>
        <ul class="mt-4 space-y-2 text-sm">
          <li><a href="/pricing" class="text-ink-700 hover:text-ink-900">Pricing</a></li>
          <li><a href="/self-hosting" class="text-ink-700 hover:text-ink-900">Self-hosting</a></li>
          <li><a href="/white-label" class="text-ink-700 hover:text-ink-900">White label</a></li>
          <li><a href="/cloud-vs-self-hosted" class="text-ink-700 hover:text-ink-900">Cloud vs self-host</a></li>
        </ul>
      </div>

      <div class="md:col-span-2">
        <h4 class="text-xs font-semibold uppercase tracking-wider text-ink-500">Company</h4>
        <ul class="mt-4 space-y-2 text-sm">
          <li><a href="/about" class="text-ink-700 hover:text-ink-900">About</a></li>
          <li><a href="/contact" class="text-ink-700 hover:text-ink-900">Contact</a></li>
          <li><a href="/privacy" class="text-ink-700 hover:text-ink-900">Privacy</a></li>
          <li><a href="/terms" class="text-ink-700 hover:text-ink-900">Terms</a></li>
        </ul>
      </div>

      <div class="md:col-span-2">
        <h4 class="text-xs font-semibold uppercase tracking-wider text-ink-500">Contact</h4>
        <ul class="mt-4 space-y-2 text-sm">
          <li>
            <a href={`mailto:${SITE.email}`} class="inline-flex items-center gap-2 text-ink-700 hover:text-ink-900">
              <Icon name="mail" size={14} /> {SITE.email}
            </a>
          </li>
          <li>
            <a href={SITE.builderUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-ink-700 hover:text-ink-900">
              <Icon name="globe" size={14} /> shabuilds.tech
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-start justify-between gap-4 border-t border-ink-100 pt-8 text-xs text-ink-500 sm:flex-row sm:items-center">
      <p>© {year} {SITE.name}. All rights reserved.</p>
      <p>
        Made with care in India.
        {' '}
        <a href={SITE.builderUrl} target="_blank" rel="noopener" class="text-ink-700 underline-offset-2 hover:underline">
          shabuilds.tech ↗
        </a>
      </p>
    </div>
  </div>
</footer>
