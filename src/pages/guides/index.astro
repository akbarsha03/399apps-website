---
import Layout from '~/layouts/Layout.astro';
import CTA from '~/components/CTA.astro';
import { GUIDES, GUIDES_ORDER, GUIDES_HUB, buildGuidesHubGraph } from '~/data/guides';

const items = GUIDES_ORDER.map((slug) => {
  const g = GUIDES[slug];
  return {
    href: `/guides/${slug}/`,
    title: g.breadcrumbLeaf,
    category: g.category,
    blurb: g.hero.directAnswer,
  };
});

const rawJsonLd = buildGuidesHubGraph();
---

<Layout
  title={GUIDES_HUB.metaTitle}
  description={GUIDES_HUB.metaDescription}
  type="website"
  keywords={GUIDES_HUB.keywords}
  rawJsonLd={rawJsonLd}
>
  <section class="relative overflow-hidden border-b border-ink-100">
    <div class="pointer-events-none absolute inset-0 grid-bg opacity-70"></div>
    <div class="container-wide relative py-16 sm:py-20">
      <nav class="mb-8 text-xs text-ink-500" aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-1.5">
          <li><a href="/" class="hover:text-ink-700">Home</a></li>
          <li class="text-ink-400">/</li>
          <li class="text-ink-800">Guides</li>
        </ol>
      </nav>
      <span class="eyebrow">GST guides</span>
      <h1 class="h1 mt-4 max-w-4xl">{GUIDES_HUB.title}</h1>
      <p class="lede mt-5 max-w-3xl">{GUIDES_HUB.lede}</p>
    </div>
  </section>

  <section class="bg-white">
    <div class="container-narrow py-16 sm:py-20">
      <ul class="grid gap-5 sm:grid-cols-2">
        {items.map((it) => (
          <li class="rounded-2xl border border-ink-100 bg-white p-6 transition hover:border-ink-200 hover:shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-wider text-brand-700">{it.category}</p>
            <h2 class="mt-2 text-lg font-semibold text-ink-900"><a class="hover:underline" href={it.href}>{it.title}</a></h2>
            <p class="mt-2 line-clamp-4 text-[15px] leading-relaxed text-ink-600">{it.blurb}</p>
            <a class="mt-3 inline-block text-sm text-brand-700 hover:underline" href={it.href}>Read the guide &rarr;</a>
          </li>
        ))}
      </ul>
      <p class="mt-8 text-sm text-ink-600">
        Looking for quick answers instead? See our <a class="text-brand-700 hover:underline" href="/answers/">GST &amp; software answers</a> or
        <a class="text-brand-700 hover:underline" href="/glossary/"> GST glossary</a>.
      </p>
    </div>
  </section>

  <CTA
    eyebrow="Try 399Apps"
    title="Affordable GST software from ₹399/month"
    body="Nidhi Books handles GST invoices, GSTR-1 and GSTR-3B exports and e-invoicing — with unlimited users. Start your free 14-day trial; no card required."
    primaryLabel="Start your free 14-day trial"
    primaryHref="https://books.399apps.com/sign-up"
    secondaryLabel="See pricing"
    secondaryHref="/pricing/"
  />
</Layout>
