---
import Layout from '~/layouts/Layout.astro';
import Icon from '~/components/Icon.astro';
import { getNotFoundCopy, LANGUAGES, localizedPath, type Lang } from '~/data/i18n';

// 404 is served as a single static file by the host (Cloudflare Pages), so
// we cannot pick the language server-side. Render all five blocks and pick
// the right one client-side from `location.pathname`.
const blocks = LANGUAGES.map((l) => ({ lang: l.code as Lang, copy: getNotFoundCopy(l.code as Lang) }));
const en = getNotFoundCopy('en');
---

<Layout title={en.seo.title} description={en.seo.description} noindex={true}>
  <section class="bg-white">
    <div class="container-narrow py-24 text-center">
      {blocks.map(({ lang, copy }) => (
        <div data-lang-block={lang} class:list={[lang !== 'en' && 'hidden']}>
          <span class="eyebrow">{copy.eyebrow}</span>
          <h1 class="h1 mt-5">{copy.title}</h1>
          <p class="lede mx-auto mt-4 max-w-xl">{copy.body}</p>
          <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
            <a href={localizedPath('/', lang)} class="btn-primary">{copy.back} <Icon name="arrow-right" size={16} /></a>
            <a href={localizedPath('/#apps', lang)} class="btn-secondary">{copy.apps}</a>
          </div>
        </div>
      ))}
    </div>
  </section>
  <script is:inline>
    (function () {
      var path = window.location.pathname || '';
      var match = path.match(/^\/(hindi|tamil|hi|ta)(?:\/|$)/);
      var lang = match ? match[1] : 'en';
      var blocks = document.querySelectorAll('[data-lang-block]');
      blocks.forEach(function (el) {
        var target = el.getAttribute('data-lang-block');
        if (target === lang) {
          el.classList.remove('hidden');
        } else {
          el.classList.add('hidden');
        }
      });
    })();
  </script>
</Layout>
