---
import Layout from '~/layouts/Layout.astro';
import Icon from '~/components/Icon.astro';
import { APPS } from '~/data/apps';
import { SITE } from '~/data/site';

const title = 'Contact — Talk to 399apps about a demo, plan or white-label.';
const description =
  'Get in touch with 399apps. Book a 20-minute demo, request a custom quote, or scope a white-label deployment. Email, WhatsApp, or the form.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact 399apps',
  url: `${SITE.url}/contact`,
  publisher: { '@type': 'Organization', name: SITE.name, url: SITE.url },
};
---

<Layout
  title={title}
  description={description}
  keywords={['contact 399apps', 'book a demo', 'business software demo', 'white label SaaS contact']}
  jsonLd={jsonLd}
>
  <section class="relative overflow-hidden border-b border-ink-100">
    <div class="pointer-events-none absolute inset-0 grid-bg opacity-60"></div>
    <div class="container-wide relative py-16 sm:py-20">
      <div class="grid items-start gap-12 lg:grid-cols-12">
        <div class="lg:col-span-5">
          <span class="eyebrow">Contact</span>
          <h1 class="h1 mt-5">Tell us what you want to build.</h1>
          <p class="lede mt-5">
            A short conversation goes a long way. Share your context — we will recommend the right app, plan and hosting mode.
          </p>

          <div class="mt-8 space-y-4">
            <a href={`mailto:${SITE.email}`} class="flex items-center gap-3 rounded-2xl border border-ink-100 bg-white px-5 py-4 transition-colors hover:border-ink-200">
              <span class="grid h-10 w-10 place-items-center rounded-lg bg-ink-50 text-ink-700">
                <Icon name="mail" size={20} />
              </span>
              <div>
                <p class="text-xs uppercase tracking-wider text-ink-500">Sales · email</p>
                <p class="font-medium text-ink-900">{SITE.email}</p>
              </div>
            </a>
            <a href={SITE.builderUrl} target="_blank" rel="noopener" class="flex items-center gap-3 rounded-2xl border border-ink-100 bg-white px-5 py-4 transition-colors hover:border-ink-200">
              <span class="grid h-10 w-10 place-items-center rounded-lg bg-ink-50 text-ink-700">
                <Icon name="globe" size={20} />
              </span>
              <div>
                <p class="text-xs uppercase tracking-wider text-ink-500">Builder</p>
                <p class="font-medium text-ink-900">shabuilds.tech ↗</p>
              </div>
            </a>
          </div>
        </div>

        <div class="lg:col-span-7">
          <form
            class="rounded-3xl border border-ink-100 bg-white p-6 shadow-[0_12px_40px_-24px_rgba(15,23,42,0.18)] sm:p-8"
            method="POST"
            name="contact"
            action="/api/contact"
            data-contact-form
            data-email={SITE.email}
          >
            <h2 class="font-display text-lg font-semibold tracking-tightish text-ink-900">Tell us a bit about you</h2>
            <p class="mt-1 text-sm text-ink-500">We reply within one business day.</p>

            <div class="mt-6 grid gap-4 sm:grid-cols-2">
              <label class="block">
                <span class="text-xs font-medium text-ink-700">Name</span>
                <input required type="text" name="name" autocomplete="name" class="mt-1.5 w-full rounded-lg border border-ink-200 bg-white px-3.5 py-2.5 text-sm text-ink-900 outline-none focus:border-ink-900 focus:ring-1 focus:ring-ink-900" />
              </label>
              <label class="block">
                <span class="text-xs font-medium text-ink-700">Work email</span>
                <input required type="email" name="email" autocomplete="email" class="mt-1.5 w-full rounded-lg border border-ink-200 bg-white px-3.5 py-2.5 text-sm text-ink-900 outline-none focus:border-ink-900 focus:ring-1 focus:ring-ink-900" />
              </label>
              <label class="block">
                <span class="text-xs font-medium text-ink-700">Company</span>
                <input type="text" name="company" autocomplete="organization" class="mt-1.5 w-full rounded-lg border border-ink-200 bg-white px-3.5 py-2.5 text-sm text-ink-900 outline-none focus:border-ink-900 focus:ring-1 focus:ring-ink-900" />
              </label>
              <label class="block">
                <span class="text-xs font-medium text-ink-700">Phone / WhatsApp</span>
                <input type="tel" name="phone" autocomplete="tel" class="mt-1.5 w-full rounded-lg border border-ink-200 bg-white px-3.5 py-2.5 text-sm text-ink-900 outline-none focus:border-ink-900 focus:ring-1 focus:ring-ink-900" />
              </label>
              <label class="block sm:col-span-2">
                <span class="text-xs font-medium text-ink-700">Interested in</span>
                <select name="app" class="mt-1.5 w-full rounded-lg border border-ink-200 bg-white px-3.5 py-2.5 text-sm text-ink-900 outline-none focus:border-ink-900 focus:ring-1 focus:ring-ink-900">
                  <option value="">— Pick an app —</option>
                  {APPS.map((a) => <option value={a.slug}>{a.name}</option>)}
                  <option value="multiple">Multiple apps</option>
                  <option value="whitelabel">White-label scope</option>
                  <option value="other">Other</option>
                </select>
              </label>
              <fieldset class="block sm:col-span-2">
                <legend class="text-xs font-medium text-ink-700">Hosting preference</legend>
                <div class="mt-1.5 flex flex-wrap gap-3">
                  {[
                    { v: 'cloud', l: 'Cloud' },
                    { v: 'selfhost', l: 'Self-hosted' },
                    { v: 'unsure', l: 'Unsure — advise me' },
                  ].map((o) => (
                    <label class="inline-flex items-center gap-2 rounded-full border border-ink-200 bg-white px-3 py-1.5 text-sm text-ink-700 has-[:checked]:border-ink-900 has-[:checked]:bg-ink-900 has-[:checked]:text-white">
                      <input type="radio" name="hosting" value={o.v} class="sr-only" /> {o.l}
                    </label>
                  ))}
                </div>
              </fieldset>
              <label class="block sm:col-span-2">
                <span class="text-xs font-medium text-ink-700">What are you trying to do?</span>
                <textarea name="message" rows="4" required minlength="10" class="mt-1.5 w-full rounded-lg border border-ink-200 bg-white px-3.5 py-2.5 text-sm text-ink-900 outline-none focus:border-ink-900 focus:ring-1 focus:ring-ink-900" placeholder="A few lines on your business, team size, current stack…"></textarea>
              </label>
              <input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" class="hidden" />
              <input type="hidden" name="intent" value={Astro.url.searchParams.get('intent') ?? ''} />
            </div>

            <div data-form-error class="mt-5 hidden rounded-lg bg-red-50 px-4 py-3 text-sm text-red-800" role="alert"></div>

            <div class="mt-6 flex flex-col-reverse items-start justify-between gap-3 sm:flex-row sm:items-center">
              <p class="text-xs text-ink-500">By submitting, you agree to our privacy practices. We don't spam.</p>
              <button type="submit" data-form-submit class="btn-primary">
                <span data-label-idle>Send</span>
                <span data-label-busy class="hidden">Sending…</span>
                <Icon name="arrow-right" size={16} />
              </button>
            </div>
          </form>

          <div data-form-success class="hidden rounded-3xl border border-emerald-200 bg-emerald-50 p-8 text-emerald-900 sm:p-10">
            <div class="flex items-start gap-4">
              <span class="grid h-10 w-10 place-items-center rounded-full bg-emerald-600 text-white">
                <Icon name="check" size={20} strokeWidth={2.5} />
              </span>
              <div>
                <h2 class="font-display text-lg font-semibold tracking-tightish">Got it. Your message is on its way.</h2>
                <p class="mt-2 text-sm leading-relaxed text-emerald-900/85">
                  We just emailed our sales inbox with your enquiry. Expect a reply from <strong>{SITE.email}</strong> within one business day.
                </p>
                <p class="mt-4 text-xs text-emerald-900/70">
                  Want to follow up directly? <a class="underline underline-offset-2" href={`mailto:${SITE.email}`}>{SITE.email}</a>
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    const form = document.querySelector<HTMLFormElement>('[data-contact-form]');
    const errorBox = document.querySelector<HTMLElement>('[data-form-error]');
    const successBox = document.querySelector<HTMLElement>('[data-form-success]');
    const submitBtn = document.querySelector<HTMLButtonElement>('[data-form-submit]');
    const labelIdle = submitBtn?.querySelector<HTMLElement>('[data-label-idle]');
    const labelBusy = submitBtn?.querySelector<HTMLElement>('[data-label-busy]');

    function setBusy(busy: boolean) {
      if (!submitBtn) return;
      submitBtn.disabled = busy;
      labelIdle?.classList.toggle('hidden', busy);
      labelBusy?.classList.toggle('hidden', !busy);
    }

    function showError(msg: string) {
      if (!errorBox) return;
      errorBox.textContent = msg;
      errorBox.classList.remove('hidden');
    }

    function hideError() {
      errorBox?.classList.add('hidden');
    }

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      hideError();
      if (!form.reportValidity()) return;
      setBusy(true);

      const data: Record<string, string> = {};
      new FormData(form).forEach((v, k) => {
        if (typeof v === 'string') data[k] = v;
      });

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          headers: {
            'content-type': 'application/json',
            'accept': 'application/json',
          },
          body: JSON.stringify(data),
        });
        let payload: { ok?: boolean; error?: string } = {};
        try {
          payload = await res.json();
        } catch {}
        if (!res.ok || !payload.ok) {
          showError(payload.error || 'Something went wrong. Please try again or email us directly.');
          setBusy(false);
          return;
        }
        form.classList.add('hidden');
        successBox?.classList.remove('hidden');
        successBox?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } catch (err) {
        showError('We could not reach the server. Please check your connection or email us directly.');
        setBusy(false);
      }
    });
  </script>
</Layout>
