---
import Layout from '~/layouts/Layout.astro';
import { SITE } from '~/data/site';

const title = 'Privacy Policy — 399apps';
const description = '399apps privacy policy: what we collect, how we use it, your rights, and how to reach us.';

const updated = '2026-05-21';
---

<Layout title={title} description={description} keywords={['399apps privacy policy', 'privacy SaaS']}>
  <section class="bg-white">
    <div class="container-narrow py-16 sm:py-20">
      <span class="eyebrow">Legal</span>
      <h1 class="h1 mt-5">Privacy Policy</h1>
      <p class="mt-3 text-sm text-ink-500">Last updated: {updated}</p>

      <div class="prose prose-ink mt-10 max-w-none">
        <p>This Privacy Policy describes how 399apps ("we", "us") collects, uses and shares information when you visit our website at <a href={SITE.url}>{SITE.domain}</a> or use our products.</p>

        <h2>Information we collect</h2>
        <ul>
          <li><strong>Account information:</strong> name, email, company, phone (when you contact us or sign up).</li>
          <li><strong>Product data:</strong> the business data you put into our products (invoices, stock, profiles, jobs). On cloud, we store it on our managed infrastructure. On self-host, it stays on your server.</li>
          <li><strong>Usage data:</strong> standard logs (IP, user agent, pages visited). We do not run third-party advertising trackers.</li>
        </ul>

        <h2>How we use information</h2>
        <ul>
          <li>To deliver and improve the products.</li>
          <li>To respond to your enquiries and provide support.</li>
          <li>To send essential service emails (account, billing, security).</li>
        </ul>

        <h2>Data sharing</h2>
        <p>We do not sell your data. We share data only with infrastructure providers we use to operate the service (e.g. Cloudflare, AWS), under appropriate data-processing terms.</p>

        <h2>Your rights</h2>
        <p>You can request a copy or deletion of your personal data by writing to <a href={`mailto:${SITE.email}`}>{SITE.email}</a>. On self-host, your data is fully under your control.</p>

        <h2>Cookies</h2>
        <p>We use only essential cookies for session and security. No third-party advertising cookies.</p>

        <h2>Contact</h2>
        <p>Questions? Write to <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.</p>
      </div>
    </div>
  </section>
</Layout>
