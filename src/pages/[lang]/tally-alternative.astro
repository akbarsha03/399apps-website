---
import AltTallyPage from '~/components/pages/AltTallyPage.astro';
import type { Lang } from '~/data/i18n';

export function getStaticPaths() {
  return [{ params: { lang: 'hi' } }, { params: { lang: 'ta' } }, { params: { lang: 'hindi' } }, { params: { lang: 'tamil' } }];
}

const lang = Astro.params.lang as Lang;
---
<AltTallyPage lang={lang} />
