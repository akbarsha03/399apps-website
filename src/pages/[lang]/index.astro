---
import Layout from '~/layouts/Layout.astro';
import Landing from '~/components/Landing.astro';
import { getLandingCopy, getHomeJsonLd, type Lang } from '~/data/i18n';
import { SITE } from '~/data/site';

export function getStaticPaths() {
  return [
    { params: { lang: 'hi' } },
    { params: { lang: 'ta' } },
    { params: { lang: 'hindi' } },
    { params: { lang: 'tamil' } },
  ];
}

const lang = Astro.params.lang as Lang;
const t = getLandingCopy(lang);
const jsonLd = getHomeJsonLd(lang, SITE.url);
---

<Layout
  title={t.seo.title}
  description={t.seo.description}
  lang={lang}
  localizedOf="/"
  jsonLd={jsonLd}
>
  <Landing lang={lang} />
</Layout>
