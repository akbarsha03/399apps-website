---
import GlossaryPage from '~/components/pages/GlossaryPage.astro';
import type { Lang } from '~/data/i18n';

export function getStaticPaths() {
  return [
    { params: { lang: 'hi' } },
    { params: { lang: 'ta' } },
    { params: { lang: 'hindi' } },
    { params: { lang: 'tamil' } },
  ];
}

const lang = Astro.params.lang as Lang;
---
<GlossaryPage lang={lang} />
