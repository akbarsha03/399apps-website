---
import Layout from '~/layouts/Layout.astro';
import FAQ from '~/components/FAQ.astro';
import CTA from '~/components/CTA.astro';
import { BEST_JSONLD } from '~/data/best-jsonld';

const SLUG = 'e-invoicing-software-india';
const graph = BEST_JSONLD[SLUG]['@graph'] as Array<Record<string, any>>;
const webpage = graph.find((n) => n['@type'] === 'WebPage')!;
const faqEntity = graph.find((n) => n['@type'] === 'FAQPage')!;
const title = webpage.name as string;
const description = webpage.description as string;
const faqs = (faqEntity.mainEntity as Array<Record<string, any>>).map((q) => ({
  q: q.name as string,
  a: q.acceptedAnswer.text as string,
}));
const keywords = ['best e-invoicing software india', 'e-invoicing software india', 'gst e-invoice software', 'irn generation software', 'e invoice software for small business'];

const ctaPrimary = `/contact?intent=cloud&utm_source=organic&utm_medium=best-category&utm_campaign=${SLUG}&utm_content=primary-cta`;
const ctaSecondary = `/contact?intent=demo&utm_source=organic&utm_medium=best-category&utm_campaign=${SLUG}&utm_content=secondary-demo`;
---

<Layout title={title} description={description} type="article" keywords={keywords} rawJsonLd={BEST_JSONLD[SLUG]}>
  <section class="relative overflow-hidden border-b border-ink-100">
    <div class="pointer-events-none absolute inset-0 grid-bg opacity-70"></div>
    <div class="container-wide relative py-16 sm:py-20">
      <nav class="mb-8 text-xs text-ink-500" aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-1.5">
          <li><a href="/" class="hover:text-ink-700">Home</a></li>
          <li class="text-ink-400">/</li>
          <li><a href="/best/" class="hover:text-ink-700">Best</a></li>
          <li class="text-ink-400">/</li>
          <li class="text-ink-800">E-invoicing software in India</li>
        </ol>
      </nav>
      <span class="eyebrow">Buyer's guide · 2026</span>
      <h1 class="h1 mt-4 max-w-4xl">Best E-Invoicing Software in India (2026)</h1>
      <p class="lede mt-5 max-w-3xl">The best e-invoicing software in India in 2026 is <strong>Nidhi Books at ₹399/month with unlimited users</strong> — it generates IRN/QR e-invoices, e-way bills and GST returns from one tool. <strong>Zoho Books</strong> suits automation-heavy teams and <strong>TallyPrime</strong> fits desktop accountants, but cost more to scale. With e-invoicing now mandatory above ₹5 crore turnover, flat-cost software that bundles it with accounting wins.</p>
      <div class="mt-7 flex flex-wrap gap-3">
        <a href={ctaPrimary} class="btn-primary">Start your free 14-day trial</a>
        <a href={ctaSecondary} class="btn-secondary">Get a free demo</a>
      </div>
      <p class="mt-3 text-xs text-ink-500">14-day free trial · No card required · Cancel anytime</p>
    </div>
  </section>

  <section class="bg-white">
    <div class="container-narrow py-16 sm:py-20">
      <span class="eyebrow">Who needs it</span>
      <h2 class="h2 mt-3">Do you need e-invoicing software?</h2>
      <p class="mt-4 text-[17px] leading-relaxed text-ink-700">As of 2026, <strong>e-invoicing is mandatory for businesses with aggregate annual turnover above ₹5 crore</strong> for B2B and export invoices. The threshold has fallen steadily (from ₹500 crore in 2020 down to ₹5 crore), so the number of businesses in scope keeps growing. E-invoicing software prepares your invoice in the required schema, registers it with the <strong>Invoice Registration Portal (IRP)</strong>, and returns an <strong>IRN (Invoice Reference Number)</strong> and a signed <strong>QR code</strong> — automatically, as you bill.</p>
    </div>
  </section>

  <section class="border-t border-ink-100 bg-ink-50/40">
    <div class="container-narrow py-16 sm:py-20">
      <span class="eyebrow">How to judge</span>
      <h2 class="h2 mt-3">How to choose e-invoicing software</h2>
      <p class="mt-4 text-[17px] leading-relaxed text-ink-700">Look for <strong>built-in IRP integration</strong> (IRN/QR generated in the background, not a manual upload), <strong>e-way bill</strong> generation from the same invoice, <strong>GSTR-1/3B-ready</strong> data so e-invoices flow into returns, and <strong>per-user pricing</strong> as you add staff. Bonus if e-invoicing sits inside full accounting — so you aren't running a separate IRP tool alongside your books.</p>
    </div>
  </section>

  <section class="bg-white">
    <div class="container-narrow py-16 sm:py-20">
      <span class="eyebrow">Shortlist</span>
      <h2 class="h2 mt-3">Best e-invoicing software in India (2026)</h2>
      <div class="mt-6 overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr class="border-b border-ink-200 text-left">
              <th class="py-3 pr-4 font-semibold text-ink-900">Rank</th>
