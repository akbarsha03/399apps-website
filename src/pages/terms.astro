---
import Layout from '~/layouts/Layout.astro';
import { SITE } from '~/data/site';

const title = 'Terms of Service — 399apps';
const description = 'Terms of service for 399apps cloud and self-hosted products.';
const updated = '2026-05-21';
---

<Layout title={title} description={description} keywords={['399apps terms', 'SaaS terms']}>
  <section class="bg-white">
    <div class="container-narrow py-16 sm:py-20">
      <span class="eyebrow">Legal</span>
      <h1 class="h1 mt-5">Terms of Service</h1>
      <p class="mt-3 text-sm text-ink-500">Last updated: {updated}</p>

      <div class="prose prose-ink mt-10 max-w-none">
        <p>These Terms govern your use of 399apps products and services.</p>

        <h2>Plans &amp; billing</h2>
        <p>Cloud is billed in INR at ₹399/month for your first app and ₹99/month for each additional app or add-on (annual billing available on request). Self-hosted and enterprise deployments are licensed under a custom quote. All prices exclude GST.</p>

        <h2>Acceptable use</h2>
        <p>Don't use 399apps for illegal activity, spam, or to harm others. We reserve the right to suspend accounts that do.</p>

        <h2>Data &amp; ownership</h2>
        <p>Your data is yours. On cloud, we store and process it to deliver the service; you can export at any time. On self-host, your data never leaves your server.</p>

        <h2>Refunds</h2>
        <p>Cloud plans are refundable on a pro-rata basis within the first 30 days. Self-host licences are refundable within 14 days if you haven't deployed to production.</p>

        <h2>Liability</h2>
        <p>Our liability is limited to the fees you paid in the preceding 12 months. We are not liable for indirect damages.</p>

        <h2>Changes</h2>
        <p>We may update these Terms with reasonable notice. Continued use after changes means you accept them.</p>

        <h2>Contact</h2>
        <p>Questions? Write to <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.</p>
      </div>
    </div>
  </section>
</Layout>
