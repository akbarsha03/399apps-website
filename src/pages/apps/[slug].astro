---
import Layout from '~/layouts/Layout.astro';
import AppIcon from '~/components/AppIcon.astro';
import AppCard from '~/components/AppCard.astro';
import Icon from '~/components/Icon.astro';
import CTA from '~/components/CTA.astro';
import FAQ from '~/components/FAQ.astro';
import { APPS } from '~/data/apps';
import { SITE } from '~/data/site';

export function getStaticPaths() {
  return APPS.map((app) => ({ params: { slug: app.slug }, props: { app } }));
}

const { app } = Astro.props;

const related = APPS.filter((a) => a.slug !== app.slug).slice(0, 3);

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Apps', item: `${SITE.url}/#apps` },
    { '@type': 'ListItem', position: 3, name: app.name, item: `${SITE.url}/apps/${app.slug}` },
  ],
};

const softwareJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: app.name,
  applicationCategory: 'BusinessApplication',
  applicationSubCategory: app.category,
  operatingSystem: 'Web, Linux (self-hosted)',
  description: app.description,
  url: `${SITE.url}/apps/${app.slug}`,
  brand: { '@type': 'Brand', name: SITE.name },
  offers: app.pricing.map((p) => ({
    '@type': 'Offer',
    name: `${p.plan} (Cloud)`,
    price: p.cloud.yearly.replace(/[^0-9]/g, '') || undefined,
    priceCurrency: 'INR',
    availability: 'https://schema.org/InStock',
    url: `${SITE.url}/pricing`,
  })),
  aggregateRating: undefined,
  publisher: { '@type': 'Organization', name: SITE.name, url: SITE.url },
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: app.faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const title = `${app.name} — ${app.tagline}`;
const description = `${app.oneLiner} Available on the 399apps cloud or fully self-hosted. Yearly plans, white-label ready.`;
---

<Layout
  title={title}
  description={description}
  type="product"
  keywords={app.keywords}
  jsonLd={[breadcrumbJsonLd, softwareJsonLd, faqJsonLd]}
>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-ink-100">
    <div class="pointer-events-none absolute inset-0 grid-bg opacity-70"></div>
    <div class={`pointer-events-none absolute -top-32 right-0 h-[360px] w-[600px] bg-gradient-to-br ${app.accent} opacity-[0.15] blur-3xl`}></div>

    <div class="container-wide relative py-16 sm:py-20">
      <nav class="mb-8 text-xs text-ink-500" aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-1.5">
          <li><a href="/" class="hover:text-ink-700">Home</a></li>
          <li class="text-ink-400">/</li>
          <li><a href="/#apps" class="hover:text-ink-700">Apps</a></li>
          <li class="text-ink-400">/</li>
          <li class="text-ink-800">{app.name}</li>
        </ol>
      </nav>

      <div class="grid items-start gap-10 lg:grid-cols-12">
        <div class="lg:col-span-7">
          <div class="flex items-center gap-3">
            <AppIcon icon={app.icon} accent={app.accent} size="md" />
            <span class="eyebrow">{app.category}</span>
          </div>
          <h1 class="h1 mt-6">{app.name}</h1>
          <p class="lede mt-4 max-w-2xl">{app.hero}</p>

          <div class="mt-7 flex flex-wrap gap-3">
            <a href="/contact?intent=demo" class="btn-primary">
              Get a demo <Icon name="arrow-right" size={16} />
            </a>
            <a href="/pricing" class="btn-secondary">See pricing</a>
            {app.sections && app.sections.length > 0 ? (
              <a href={`#${app.sections[0].id}`} class="btn-ghost">
                {app.sections[0].eyebrow} <Icon name="arrow-right" size={14} />
              </a>
            ) : (
              <a href="/self-hosting" class="btn-ghost">
                Self-host details <Icon name="arrow-up-right" size={14} />
              </a>
            )}
          </div>

          <ul class="mt-8 flex flex-wrap items-center gap-x-5 gap-y-2 text-xs text-ink-500">
            <li class="inline-flex items-center gap-1.5"><Icon name="cloud" size={14} class="text-brand-600" /> Cloud · yearly</li>
            <li class="inline-flex items-center gap-1.5"><Icon name="server" size={14} class="text-ink-700" /> Self-hosted · yearly</li>
            <li class="inline-flex items-center gap-1.5"><Icon name="check" size={14} class="text-emerald-600" /> Unlimited users + exports</li>
            <li class="inline-flex items-center gap-1.5"><Icon name="shield" size={14} class="text-emerald-600" /> White-label ready</li>
          </ul>
        </div>

        <aside class="lg:col-span-5">
          <div class="rounded-2xl border border-ink-100 bg-white p-6 shadow-[0_12px_40px_-24px_rgba(15,23,42,0.18)]">
            <h2 class="font-display text-base font-semibold tracking-tightish text-ink-900">At a glance</h2>
            <dl class="mt-4 grid grid-cols-2 gap-y-4 text-sm">
              <dt class="text-ink-500">Status</dt>
              <dd class="text-right font-medium text-emerald-700">Available</dd>
              <dt class="text-ink-500">Audience</dt>
              <dd class="text-right text-ink-800">{app.audiences.slice(0, 2).join(', ')}</dd>
              <dt class="text-ink-500">Hosting</dt>
              <dd class="text-right text-ink-800">Cloud · Self-host</dd>
              <dt class="text-ink-500">Users</dt>
              <dd class="text-right font-medium text-ink-800">Unlimited</dd>
              <dt class="text-ink-500">Exports</dt>
              <dd class="text-right font-medium text-ink-800">Unlimited</dd>
              <dt class="text-ink-500">Billing</dt>
              <dd class="text-right text-ink-800">Yearly · INR</dd>
              <dt class="text-ink-500">White-label</dt>
              <dd class="text-right text-ink-800">Yes</dd>
            </dl>
            <div class="mt-5 border-t border-ink-100 pt-5">
              <p class="text-xs text-ink-500">Starting from</p>
              <p class="mt-1 text-2xl font-semibold tracking-tightish text-ink-900">
                {app.pricing[0]?.cloud.yearly}
              </p>
              <p class="mt-0.5 text-xs text-ink-500">cloud · billed yearly · unlimited users</p>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Description / lede -->
  <section class="border-b border-ink-100 bg-white">
    <div class="container-narrow py-16 sm:py-20">
      <div class="grid gap-10 md:grid-cols-12">
        <div class="md:col-span-4">
          <span class="eyebrow">Overview</span>
          <h2 class="h2 mt-3">{app.tagline}</h2>
        </div>
        <div class="md:col-span-8">
          <p class="text-[17px] leading-relaxed text-ink-700">{app.description}</p>
          <div class="mt-6 grid gap-3 sm:grid-cols-2">
            <div class="rounded-xl border border-ink-100 bg-ink-50/40 p-4">
              <p class="text-xs uppercase tracking-wider text-ink-500">Best for</p>
              <p class="mt-1.5 text-sm text-ink-800">{app.audiences.join(' · ')}</p>
            </div>
            <div class="rounded-xl border border-ink-100 bg-ink-50/40 p-4">
              <p class="text-xs uppercase tracking-wider text-ink-500">Works across</p>
              <p class="mt-1.5 text-sm text-ink-800">{app.industries.join(' · ')}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="bg-white">
    <div class="container-wide py-16 sm:py-20">
      <div class="mb-10 max-w-2xl">
        <span class="eyebrow">What's inside</span>
        <h2 class="h2 mt-3">Features that earn their place.</h2>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {app.features.map((feature) => (
          <article class="card">
            <span class={`inline-grid h-9 w-9 place-items-center rounded-lg bg-gradient-to-br ${app.accent} text-white`}>
              <Icon name="sparkle" size={18} />
            </span>
            <h3 class="mt-4 font-display text-base font-semibold tracking-tightish text-ink-900">{feature.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-600">{feature.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- App-specific deep-dive sections (e.g. reports & exports for Books) -->
  {app.sections?.map((section) => (
    <section id={section.id} class="border-t border-ink-100 bg-ink-50/40">
      <div class="container-wide py-16 sm:py-20">
        <div class="mb-10 max-w-3xl">
          <span class="eyebrow">{section.eyebrow}</span>
          <h2 class="h2 mt-3">{section.title}</h2>
          {section.description && <p class="lede mt-3">{section.description}</p>}
        </div>

        <div class="space-y-12">
          {section.groups.map((group) => (
            <div>
              <div class="mb-5 flex flex-wrap items-baseline justify-between gap-3 border-b border-ink-100 pb-3">
                <h3 class="font-display text-lg font-semibold tracking-tightish text-ink-900">{group.title}</h3>
                {group.description && <p class="text-sm text-ink-500">{group.description}</p>}
              </div>
              <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                {group.items.map((item) => (
                  <li class="rounded-2xl border border-ink-100 bg-white p-5">
                    <div class="flex items-start gap-3">
                      <span class={`mt-0.5 inline-grid h-7 w-7 place-items-center rounded-md bg-gradient-to-br ${app.accent} text-white`}>
                        <Icon name="check" size={14} strokeWidth={2.4} />
                      </span>
                      <div class="min-w-0">
                        <p class="font-display text-[15px] font-semibold tracking-tightish text-ink-900">{item.title}</p>
                        <p class="mt-1.5 text-sm leading-relaxed text-ink-600">{item.body}</p>
                      </div>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>

        {section.note && (
          <p class="mt-10 max-w-3xl rounded-2xl border border-amber-200 bg-amber-50 px-5 py-4 text-sm leading-relaxed text-amber-900">
            <span class="font-semibold">Heads-up. </span>{section.note}
          </p>
        )}
      </div>
    </section>
  ))}

  <!-- Pricing -->
  <section class="border-y border-ink-100 bg-ink-50/40">
    <div class="container-wide py-16 sm:py-20">
      <div class="mb-10 max-w-2xl">
        <span class="eyebrow">Pricing for {app.shortName}</span>
        <h2 class="h2 mt-3">One plan, every app. Unlimited users.</h2>
        <p class="lede mt-3">
          Same yearly pricing as every product on 399apps. No per-seat gotchas — unlimited users and exports on every plan. Growth includes one free core-workflow customisation.
        </p>
      </div>

      <div class="overflow-x-auto rounded-2xl border border-ink-100 bg-white">
        <table class="w-full border-collapse text-sm">
          <thead class="bg-ink-50/60 text-left text-xs uppercase tracking-wider text-ink-500">
            <tr>
              <th class="px-5 py-4 font-medium">Plan</th>
              <th class="px-5 py-4 font-medium">Audience</th>
              <th class="px-5 py-4 font-medium">Cloud (yearly)</th>
              <th class="px-5 py-4 font-medium">Self-host (yearly)</th>
              <th class="px-5 py-4"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-ink-100 text-ink-800">
            {app.pricing.map((p) => (
              <tr>
                <td class="px-5 py-4 font-medium">{p.plan}</td>
                <td class="px-5 py-4 text-ink-600">{p.audience}</td>
                <td class="px-5 py-4">
                  <div class="font-semibold text-ink-900">{p.cloud.yearly}</div>
                  {p.cloud.note && <div class="text-xs text-ink-500">{p.cloud.note}</div>}
                </td>
                <td class="px-5 py-4">
                  <div class="font-semibold text-ink-900">{p.selfHost.yearly}</div>
                  {p.selfHost.note && <div class="text-xs text-ink-500">{p.selfHost.note}</div>}
                </td>
                <td class="px-5 py-4 text-right">
                  <a href="/contact?intent=demo" class="btn-secondary text-xs">Talk to us</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <p class="mt-4 text-xs text-ink-500">
        Prices are indicative for India and exclude GST. International pricing on request. White-label and enterprise scopes are bespoke.
      </p>
    </div>
  </section>

  <FAQ items={app.faqs} title={`${app.shortName} — FAQs`} />

  <!-- Related -->
  <section class="bg-white">
    <div class="container-wide py-16 sm:py-20">
      <div class="mb-10 max-w-2xl">
        <span class="eyebrow">More from 399apps</span>
        <h2 class="h2 mt-3">Other apps you might like.</h2>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {related.map((r) => <AppCard app={r} />)}
      </div>
    </div>
  </section>

  <CTA
    eyebrow={`Ready to roll ${app.shortName}?`}
    title={`Let's get ${app.name} live for you.`}
    body="A short call. We will scope your setup, recommend cloud vs self-host honestly, and quote without games."
    primaryLabel="Get a demo"
    primaryHref={`/contact?intent=demo&app=${app.slug}`}
    secondaryLabel="See pricing"
    secondaryHref="/pricing"
  />
</Layout>
