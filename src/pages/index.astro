---
import Layout from '~/layouts/Layout.astro';
import Landing from '~/components/Landing.astro';
import { getLandingCopy, getHomeJsonLd } from '~/data/i18n';
import { SITE } from '~/data/site';

const lang = 'en' as const;
const t = getLandingCopy(lang);
const jsonLd = getHomeJsonLd(lang, SITE.url);
---

<Layout
  title={t.seo.title}
  description={t.seo.description}
  lang={lang}
  localizedOf="/"
  keywords={['business SaaS India', 'self-hosted business apps', 'accounting software', 'inventory software', 'GST software', 'white label SaaS', 'affordable business software']}
  jsonLd={jsonLd}
>
  <Landing lang={lang} />
</Layout>
