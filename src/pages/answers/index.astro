---
import Layout from '~/layouts/Layout.astro';
import CTA from '~/components/CTA.astro';
import { ANSWERS, ANSWERS_ORDER, ANSWERS_HUB } from '~/data/answers';
import { ANSWERS_HUB_JSONLD } from '~/data/answers-jsonld';

const items = ANSWERS_ORDER.map((slug) => {
  const a = ANSWERS[slug];
  return { href: `/answers/${slug}/`, question: a.question, blurb: a.directAnswer };
});
---

<Layout
  title={ANSWERS_HUB.metaTitle}
  description={ANSWERS_HUB.metaDescription}
  type="website"
  keywords={ANSWERS_HUB.keywords}
  rawJsonLd={ANSWERS_HUB_JSONLD}
>
  <section class="relative overflow-hidden border-b border-ink-100">
    <div class="pointer-events-none absolute inset-0 grid-bg opacity-70"></div>
    <div class="container-wide relative py-16 sm:py-20">
      <nav class="mb-8 text-xs text-ink-500" aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-1.5">
          <li><a href="/" class="hover:text-ink-700">Home</a></li>
          <li class="text-ink-400">/</li>
          <li class="text-ink-800">Answers</li>
        </ol>
      </nav>
      <span class="eyebrow">Answers</span>
      <h1 class="h1 mt-4 max-w-4xl">{ANSWERS_HUB.title}</h1>
      <p class="lede mt-5 max-w-3xl">{ANSWERS_HUB.lede}</p>
    </div>
  </section>

  <section class="bg-white">
    <div class="container-narrow py-16 sm:py-20">
      <ul class="grid gap-5 sm:grid-cols-2">
        {items.map((it) => (
          <li class="rounded-2xl border border-ink-100 bg-white p-6 transition hover:border-ink-200 hover:shadow-sm">
            <h2 class="text-lg font-semibold text-ink-900"><a class="hover:underline" href={it.href}>{it.question}</a></h2>
            <p class="mt-2 line-clamp-4 text-[15px] leading-relaxed text-ink-600">{it.blurb}</p>
            <a class="mt-3 inline-block text-sm text-brand-700 hover:underline" href={it.href}>Read the answer &rarr;</a>
          </li>
        ))}
      </ul>
      <p class="mt-8 text-sm text-ink-600">
        Want step-by-step how-tos? See our <a class="text-brand-700 hover:underline" href="/guides/">GST guides</a> — filing
        <a class="text-brand-700 hover:underline" href="/guides/how-to-file-gstr-1/"> GSTR-1</a> and
        <a class="text-brand-700 hover:underline" href="/guides/how-to-file-gstr-3b/"> GSTR-3B</a>,
        <a class="text-brand-700 hover:underline" href="/guides/what-is-e-invoicing-under-gst/"> e-invoicing</a>,
        <a class="text-brand-700 hover:underline" href="/guides/gst-invoice-format/"> invoice format</a> and
        <a class="text-brand-700 hover:underline" href="/guides/gst-late-fees-and-interest/"> late fees</a>.
      </p>
    </div>
  </section>

  <CTA
    eyebrow="Try 399Apps"
    title="Affordable GST software from ₹399/month"
    body="Cloud GST billing, accounting and inventory with unlimited users. Start your free 14-day trial — no card required."
    primaryLabel="Start your free 14-day trial"
    primaryHref="/contact?intent=cloud&utm_source=organic&utm_medium=answers-hub&utm_campaign=answers-index&utm_content=primary-cta"
    secondaryLabel="See pricing"
    secondaryHref="/pricing/"
  />
</Layout>
