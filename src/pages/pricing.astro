---
import Layout from '~/layouts/Layout.astro';
import Icon from '~/components/Icon.astro';
import CTA from '~/components/CTA.astro';
import FAQ from '~/components/FAQ.astro';
import AppIcon from '~/components/AppIcon.astro';
import { APPS, STANDARD_PRICING, BUNDLE_PRICING } from '~/data/apps';
import { SITE } from '~/data/site';

const title = 'Pricing — 399apps. One plan. Every app. Unlimited users.';
const description =
  'Transparent yearly pricing for every 399apps product — Nidhi Books, Inventory, the Books + Inventory bundle, Matrimonials and Job Portal. Same plan, every app. Unlimited users + exports. Growth includes one free core-workflow customisation.';

const faqs = [
  { q: 'Why is the pricing the same for every app?', a: 'Because we keep the apps roughly the same size. One small surface area, one honest price. Pick the app, pick the plan, the bill is the same whether you go for Books or Matrimonials or the Job Portal — the Books + Inventory bundle is the only exception, and it is 10% cheaper.' },
  { q: 'What does the bundle save me?', a: 'The Books + Inventory bundle is 10% off the standard 399apps plan — ₹22,500/year cloud (Starter) instead of ₹25,000. Compared to buying Books and Inventory as separate subscriptions, the bundle costs roughly half — you save about 55% on the Starter cloud tier.' },
  { q: 'What does "unlimited users" actually mean?', a: 'Every plan ships with no per-seat caps. Add as many internal team users, admins, members, profiles, jobs or candidates as your business needs — your bill does not change. We think per-seat pricing punishes you for growing.' },
  { q: 'What is the "1 free core customisation" on Growth?', a: 'When you sign up to a Growth plan we include one customisation that solves a core workflow specific to your business. A warehouse operator might want a one-tap barcode-scan inward flow tuned to their floor. A matrimony platform might want a community-specific verification step. We scope it with you, build it, and ship it as part of your subscription.' },
  { q: 'Can I request additional customisations?', a: 'Yes, on Starter and Growth. Additional customisations are scoped on request and subject to engineering availability and relevance to the product roadmap. We won\'t fork a private build for every request, but if it benefits other 399apps customers too, it goes on the roadmap and we will price it transparently.' },
  { q: 'Is GST included?', a: 'No — prices listed are exclusive of GST. We add applicable GST on the invoice based on your billing location.' },
  { q: 'Do you bill monthly?', a: '399apps is yearly-first because it keeps pricing honest and predictable. We will consider quarterly plans on enterprise scopes.' },
  { q: 'Can I switch from cloud to self-host later (or back)?', a: 'Yes. We migrate your data, set up the new environment with you, and transfer the remaining term as credit on the new plan.' },
  { q: 'Do you offer non-profit or community discounts?', a: 'Yes. Registered non-profits, community organisations and educational projects can get a 25–50% discount. Write to us with proof of registration.' },
  { q: 'What payment methods do you accept?', a: 'UPI, bank transfer (NEFT/RTGS) and cards for India. International customers can pay via card or wire.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Layout
  title={title}
  description={description}
  keywords={['399apps pricing', 'business SaaS pricing India', 'self-hosted SaaS pricing', 'unlimited user SaaS', 'matrimonial software cost', 'job portal pricing']}
  jsonLd={jsonLd}
>
  <section class="relative overflow-hidden border-b border-ink-100">
    <div class="pointer-events-none absolute inset-0 grid-bg opacity-60"></div>
    <div class="pointer-events-none absolute -top-32 left-1/2 h-[360px] w-[700px] -translate-x-1/2 rounded-full bg-gradient-to-tr from-brand-200/40 via-rose-200/30 to-amber-200/30 blur-3xl"></div>
    <div class="container-wide relative py-16 sm:py-20">
      <div class="mx-auto max-w-3xl text-center">
        <span class="eyebrow">Pricing</span>
        <h1 class="h1 mt-5">One plan. Every app. <span class="bg-gradient-to-r from-brand-700 via-brand-500 to-amber-500 bg-clip-text text-transparent">Unlimited users.</span></h1>
        <p class="lede mt-5">
          Same yearly pricing across every product — Books, Inventory, the bundle, Matrimonials, Job Portal. Unlimited users and exports on every plan. Growth includes one free core-workflow customisation, on the house.
        </p>
        <ul class="mt-8 flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-sm text-ink-600">
          <li class="inline-flex items-center gap-1.5"><Icon name="check" size={14} class="text-emerald-600" /> Unlimited users</li>
          <li class="inline-flex items-center gap-1.5"><Icon name="check" size={14} class="text-emerald-600" /> Unlimited exports</li>
          <li class="inline-flex items-center gap-1.5"><Icon name="check" size={14} class="text-emerald-600" /> Cloud or self-host</li>
          <li class="inline-flex items-center gap-1.5"><Icon name="check" size={14} class="text-emerald-600" /> White-label ready</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Pricing cards -->
  <section class="bg-white">
    <div class="container-wide py-16 sm:py-20">
      <div class="grid gap-5 lg:grid-cols-3">
        {STANDARD_PRICING.map((p, idx) => {
          const featured = idx === 1;
          return (
            <article class:list={['relative flex flex-col gap-5 rounded-2xl border bg-white p-7', featured ? 'border-brand-600 shadow-[0_24px_60px_-30px_rgba(220,38,38,0.4)] ring-1 ring-brand-600/20' : 'border-ink-100']}>
              {featured && (
                <span class="absolute -top-3 left-7 inline-flex items-center gap-1.5 rounded-full bg-brand-600 px-3 py-1 text-[11px] font-semibold uppercase tracking-wider text-white shadow-[0_4px_12px_-6px_rgba(220,38,38,0.7)]">
                  Most popular
                </span>
              )}
              <div class="flex items-center justify-between">
                <h2 class="font-display text-xl font-semibold tracking-tightish text-ink-900">{p.plan}</h2>
                <span class="text-xs uppercase tracking-wider text-ink-500">{p.audience}</span>
              </div>
              <p class="text-sm leading-relaxed text-ink-600">
                {idx === 0 && 'A complete product, one yearly fee. Unlimited users + exports on every app.'}
                {idx === 1 && 'Everything in Starter, plus one customisation tuned to your core workflow.'}
                {idx === 2 && 'For bigger ambitions — multi-tenant, SSO, source access, on-call. Talk to us.'}
              </p>

              <div class="grid gap-3 sm:grid-cols-2">
                <div class="rounded-xl border border-ink-100 bg-ink-50/40 p-4">
                  <p class="inline-flex items-center gap-1.5 text-xs uppercase tracking-wider text-ink-500">
                    <Icon name="cloud" size={12} /> Cloud
                  </p>
                  <p class="mt-2 font-display text-2xl font-semibold text-ink-900">{p.cloud.yearly}</p>
                  {p.cloud.note && <p class="mt-1 text-[11.5px] leading-snug text-ink-500">{p.cloud.note}</p>}
                </div>
                <div class="rounded-xl border border-ink-100 bg-ink-50/40 p-4">
                  <p class="inline-flex items-center gap-1.5 text-xs uppercase tracking-wider text-ink-500">
                    <Icon name="server" size={12} /> Self-host
                  </p>
                  <p class="mt-2 font-display text-2xl font-semibold text-ink-900">{p.selfHost.yearly}</p>
                  {p.selfHost.note && <p class="mt-1 text-[11.5px] leading-snug text-ink-500">{p.selfHost.note}</p>}
                </div>
              </div>

              <ul class="space-y-2 text-sm text-ink-700">
                {idx === 0 && [
                  'Unlimited users',
                  'Unlimited exports',
                  'Cloud or self-host',
                  'Email support',
                  'Daily backups (cloud)',
                ].map((f) => (
                  <li class="flex items-start gap-2"><Icon name="check" size={15} class="mt-0.5 text-emerald-600" /> {f}</li>
                ))}
                {idx === 1 && [
                  'Everything in Starter',
                  '1 free core customisation',
                  'Priority email support',
                  'Onboarding session',
                  'Additional customisations on request',
                ].map((f) => (
                  <li class="flex items-start gap-2"><Icon name="check" size={15} class="mt-0.5 text-emerald-600" /> {f}</li>
                ))}
                {idx === 2 && [
                  'Everything in Growth',
                  'Source access (self-host)',
                  'SSO, audit logs, custom SLA',
                  'On-call engineering support',
                  'Bespoke roadmap',
                ].map((f) => (
                  <li class="flex items-start gap-2"><Icon name="check" size={15} class="mt-0.5 text-emerald-600" /> {f}</li>
                ))}
              </ul>

              <a
                href={`/contact?intent=demo&plan=${p.plan.toLowerCase()}`}
                class:list={['mt-auto', featured ? 'btn-primary' : 'btn-secondary']}
              >
                {idx === 2 ? 'Talk to us' : `Choose ${p.plan}`} <Icon name="arrow-right" size={14} />
              </a>
            </article>
          );
        })}
      </div>

      <p class="mt-6 text-center text-xs text-ink-500">
        Prices are in INR and exclude GST. International pricing on request. The <a href="/apps/books-inventory-bundle" class="font-medium text-ink-700 underline-offset-2 hover:underline">Books + Inventory bundle</a> ships at 10% off these prices.
      </p>
    </div>
  </section>

  <!-- Bundle discount card -->
  <section class="border-y border-ink-100 bg-white">
    <div class="container-wide py-14 sm:py-16">
      <div class="grid items-center gap-8 rounded-3xl border border-violet-200 bg-gradient-to-br from-violet-50 to-fuchsia-50 p-8 sm:p-10 lg:grid-cols-12">
        <div class="lg:col-span-7">
          <span class="inline-flex items-center gap-2 rounded-full bg-violet-600/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-violet-700">
            Bundle saves 10%
          </span>
          <h2 class="h2 mt-4">Books + Inventory together: 10% off.</h2>
          <p class="lede mt-3">
            Take Nidhi Books and Nidhi Inventory in one subscription and we knock 10% off every plan tier — and you skip the integration project entirely.
          </p>
          <a href="/apps/books-inventory-bundle" class="btn-secondary mt-6">
            See the bundle <Icon name="arrow-right" size={14} />
          </a>
        </div>
        <div class="lg:col-span-5">
          <div class="rounded-2xl border border-ink-100 bg-white p-5">
            <p class="text-xs uppercase tracking-wider text-ink-500">Bundle pricing</p>
            <ul class="mt-3 divide-y divide-ink-100">
              {BUNDLE_PRICING.map((p) => (
                <li class="flex items-baseline justify-between gap-4 py-3 text-sm">
                  <span class="font-medium text-ink-900">{p.plan}</span>
                  <span class="text-ink-700">
                    <span class="font-semibold">{p.cloud.yearly}</span>
                    <span class="text-ink-400"> cloud · </span>
                    <span class="font-semibold">{p.selfHost.yearly}</span>
                    <span class="text-ink-400"> self-host</span>
                  </span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Customisation explainer -->
  <section class="border-y border-ink-100 bg-ink-50/40">
    <div class="container-wide py-16 sm:py-20">
      <div class="grid items-start gap-10 lg:grid-cols-12">
        <div class="lg:col-span-5">
          <span class="eyebrow">Growth plan perk</span>
          <h2 class="h2 mt-3">One customisation, on us.</h2>
          <p class="lede mt-4">
            Every business has a workflow that defines how it runs. On the Growth plan we build one of those for you, free, as part of the subscription.
          </p>
          <a href="/contact?intent=growth" class="btn-secondary mt-6">
            Scope a customisation <Icon name="arrow-right" size={14} />
          </a>
        </div>

        <div class="grid gap-4 lg:col-span-7 sm:grid-cols-2">
          {[
            { t: 'Warehouse — quick-scan inward', b: 'A one-tap barcode-scan inward flow that fits how your team physically receives stock, reducing onboarding time per supplier.' },
            { t: 'Matrimony — community KYC', b: 'A verification step calibrated to your community\'s norms — extra fields, document checks, manual review queues, your call.' },
            { t: 'Books — industry GST template', b: 'GST templates and reverse-charge handling tuned to your industry\'s common transaction types.' },
            { t: 'Job board — niche scoring', b: 'A candidate scoring rule tuned to the skills and signals that actually matter in your industry.' },
          ].map((c) => (
            <article class="card">
              <h3 class="font-display text-base font-semibold tracking-tightish text-ink-900">{c.t}</h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-600">{c.b}</p>
            </article>
          ))}
        </div>
      </div>

      <p class="mt-6 text-xs text-ink-500">
        Additional customisations are available on Starter and Growth — scoped on request, subject to engineering availability and relevance to the roadmap.
      </p>
    </div>
  </section>

  <!-- Which apps -->
  <section class="bg-white">
    <div class="container-wide py-16 sm:py-20">
      <div class="mb-10 max-w-2xl">
        <span class="eyebrow">Same pricing, every app</span>
        <h2 class="h2 mt-3">Five apps. One plan.</h2>
        <p class="lede mt-3">
          Pick any product in the 399apps catalogue — same plans, same prices, same unlimited-user policy.
        </p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {APPS.map((app) => (
          <a href={`/apps/${app.slug}`} class="group flex items-center gap-4 rounded-2xl border border-ink-100 bg-white p-5 transition-all duration-200 hover:border-ink-200 hover:shadow-[0_8px_28px_-12px_rgba(15,23,42,0.12)]">
            <AppIcon icon={app.icon} accent={app.accent} size="md" />
            <div class="min-w-0 flex-1">
              <h3 class="font-display text-[15px] font-semibold tracking-tightish text-ink-900">{app.name}</h3>
              <p class="mt-0.5 text-xs text-ink-500">{app.category}</p>
            </div>
            <Icon name="arrow-right" size={14} class="text-ink-400 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
        ))}
      </div>
    </div>
  </section>

  <FAQ items={faqs} title="Pricing — FAQs" />

  <CTA
    eyebrow="Need a custom scope?"
    title="Enterprise, white-label or multi-app? Let's quote it."
    body="Tell us about your team, your industry and your roll-out plan. We will come back with a clean, honest proposal."
    primaryLabel="Request a quote"
    primaryHref="/contact?intent=quote"
    secondaryLabel="See white-label"
    secondaryHref="/white-label"
  />
</Layout>
